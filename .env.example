COMPOSE_PROJECT_NAME=mol-assistant

GATEWAY_PORT=8080
FRONTEND_PORT=8081

AUTH_URL=http://auth:8000
AI_AGENT_URL=http://ai-agent:8000
INGESTOR_URL=http://ingestor:8000

# Auth database (dedicated Postgres)
AUTH_DB_USER=auth
AUTH_DB_PASSWORD=auth
AUTH_DB_NAME=auth
AUTH_DATABASE_URL=postgresql+asyncpg://auth:auth@auth-db:5432/auth

# Auth (SSO). For HTTPS cross-domain set COOKIE_SECURE=true and COOKIE_SAMESITE=none.
JWT_SECRET=mol-dev-secret-change-me
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
FRONTEND_URL=http://localhost:8081
# Yandex OAuth (optional — leave empty to disable the "Яндекс"/"ДВФУ" buttons)
YANDEX_CLIENT_ID=
YANDEX_SECRET_ID=
YANDEX_REDIRECT_DOMAIN=http://localhost:8081/api/auth

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=mol_documents

ANTHROPIC_API_KEY=
AI_AGENT_MODEL=claude-sonnet-4-6

AIRFLOW_IMAGE=apache/airflow:3.0.6
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./services/ingestor/airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW_API_PORT=8082
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
